---
import { reviews } from "../data/reviews";

// Reserves this many slots for testimonials. Real reviews (from reviews.ts)
// fill the slots first; any remaining slots show as "coming soon" so the
// section keeps a consistent size while you're still collecting reviews.
const REVIEW_SLOTS = 6;
const emptySlots = Math.max(REVIEW_SLOTS - reviews.length, 0);
const placeholders = Array.from({ length: emptySlots });
---
<section id="reviews" class="section">
  <div class="container">
    <p class="eyebrow">Customer reviews</p>
    <h2>What Our Customers Say</h2>
    <p class="section-intro">Reviews from real customers across the Arun district — more being added as our round grows.</p>

    <div class="grid grid-3">
      {reviews.map((review) => (
        <div class="card review-card">
          <div class="stars">{"★".repeat(review.rating)}{"☆".repeat(5 - review.rating)}</div>
          <p class="quote">"{review.quote}"</p>
          <p class="reviewer">{review.name} — {review.location}</p>
        </div>
      ))}
      {placeholders.map(() => (
        <div class="card review-card placeholder">
          <span class="placeholder-icon">💬</span>
          <p class="placeholder-text">Testimonial coming soon</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-intro { max-width: 640px; color: var(--color-text-muted); margin-bottom: 2rem; }
  .stars { color: #f5a623; letter-spacing: 2px; margin-bottom: 0.5rem; }
  .quote { font-style: italic; color: var(--color-text); }
  .reviewer { color: var(--color-text-muted); font-size: 0.9rem; margin: 0; }
  .placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 140px;
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    border-style: dashed;
  }
  .placeholder-icon { font-size: 1.5rem; }
  .placeholder-text { margin: 0; font-size: 0.9rem; }
</style>
