---
import { site } from "../data/site-config";
---
<footer class="footer">
  <div class="container footer-inner">
    <div>
      <h4>{site.name}</h4>
      <p>Professional exterior cleaning for homes across West Sussex. Reliable, chemical-free and locally based.</p>
    </div>
    <div>
      <h5>Services</h5>
      <ul>
        <li><a href="#services">Window Cleaning</a></li>
        <li><a href="#services">Fascia & Soffit Cleaning</a></li>
        <li><a href="#services">Conservatory Cleaning</a></li>
        <li><a href="#services">Solar Panel Cleaning</a></li>
      </ul>
    </div>
    <div>
      <h5>Contact</h5>
      <ul>
        <li><a href={site.phoneHref}>{site.phone}</a></li>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
        <li><a href="#areas">Areas Covered</a></li>
        <li><a href="#quote">Free Quote</a></li>
      </ul>
    </div>
  </div>
  <div class="container copyright">
    © {site.year} {site.name}. All rights reserved. {site.areaLabel}.
  </div>
</footer>

<style>
  .footer { background: var(--color-bg-alt); padding: 3rem 0 1.5rem; margin-top: 2rem; }
  .footer-inner { display: grid; gap: 2rem; grid-template-columns: 1fr; }
  @media (min-width: 700px) { .footer-inner { grid-template-columns: 2fr 1fr 1fr; } }
  .footer h4, .footer h5 { margin-bottom: 0.75rem; }
  .footer ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.4rem; }
  .footer a { color: var(--color-text-muted); text-decoration: none; }
  .copyright { border-top: 1px solid var(--color-border); margin-top: 2rem; padding-top: 1.5rem; color: var(--color-text-muted); font-size: 0.85rem; }
</style>
