---
const points = [
  { title: "Pure water — no chemicals", text: "Our water-fed pole system uses purified water only. Better for your property, your garden, and the environment." },
  { title: "Fully contactless service", text: "We clean the outside without needing to enter your home. No disruption to your day." },
  { title: "Flexible scheduling", text: "Weekly, fortnightly, monthly or one-off. We work around your life, not the other way around." },
  { title: "No-obligation quotes", text: "Get a free quote with no pressure. If the price doesn't work for you, no hard feelings." },
];

const stats = [
  { value: "100%", label: "Chemical-free window cleaning" },
  { value: "4+", label: "Services under one local provider" },
  { value: "Free", label: "No-obligation quote, every time" },
  { value: "Local", label: "Based in West Sussex — not a franchise" },
];
---
<section id="why" class="section why-section">
  <div class="container why-grid">
    <div>
      <p class="eyebrow">Why KleenViews</p>
      <h2>A local service you can actually rely on</h2>
      <p class="section-intro">
        No call centres, no subcontractors, no surprises. Just a local professional who turns
        up when agreed and leaves your property looking its best.
      </p>

      <div class="points">
        {points.map((point) => (
          <div class="point">
            <span class="check">✓</span>
            <div>
              <h4>{point.title}</h4>
              <p>{point.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="grid grid-2 stats">
      {stats.map((stat) => (
        <div class="stat">
          <div class="stat-value">{stat.value}</div>
          <div class="stat-label">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why-section {
    background: var(--color-navy);
    color: var(--color-text-on-dark);
  }
  .why-section h2 { color: var(--color-text-on-dark); }
  .why-section .eyebrow { color: var(--color-accent); }
  .why-grid {
    display: grid;
    gap: 2.5rem;
    align-items: start;
  }
  @media (min-width: 800px) {
    .why-grid { grid-template-columns: 1.1fr 1fr; }
  }
  .section-intro { color: var(--color-text-muted-on-dark); margin-bottom: 2rem; max-width: 520px; }
  .points { display: flex; flex-direction: column; gap: 1.25rem; }
  .point { display: flex; gap: 0.75rem; align-items: flex-start; }
  .check {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
  }
  .point h4 { margin: 0 0 0.25rem; color: var(--color-text-on-dark); }
  .point p { margin: 0; color: var(--color-text-muted-on-dark); font-size: 0.95rem; }
  .stats { align-self: start; }
  .stat {
    background: var(--color-navy-card);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-align: center;
  }
  .stat-value { font-size: 2rem; font-weight: 700; color: var(--color-accent); }
  .stat-label { color: var(--color-text-muted-on-dark); font-size: 0.85rem; margin-top: 0.4rem; }
</style>
