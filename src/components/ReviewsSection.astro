---
import { reviews } from "../data/reviews";
---
{reviews.length > 0 && (
  <section id="reviews" class="section">
    <div class="container">
      <p class="eyebrow">Customer reviews</p>
      <h2>What Our Customers Say</h2>
      <div class="grid grid-3">
        {reviews.map((review) => (
          <div class="card review-card">
            <div class="stars">{"★".repeat(review.rating)}{"☆".repeat(5 - review.rating)}</div>
            <p class="quote">"{review.quote}"</p>
            <p class="reviewer">{review.name} — {review.location}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .stars { color: #f5a623; letter-spacing: 2px; margin-bottom: 0.5rem; }
  .quote { font-style: italic; color: var(--color-text); }
  .reviewer { color: var(--color-text-muted); font-size: 0.9rem; margin: 0; }
</style>
