---
// Change this number whenever you want more or fewer placeholder slots.
const PHOTO_SLOTS = 3;
const placeholders = Array.from({ length: PHOTO_SLOTS });
---
<section id="gallery" class="section">
  <div class="container">
    <p class="eyebrow">Our work</p>
    <h2>Before & After</h2>
    <p class="section-intro">Photos coming soon — check back to see real results from your local area.</p>

    <div class="grid grid-3">
      {placeholders.map(() => (
        <div class="card photo-placeholder">
          <span class="photo-icon">📷</span>
          <p>Photo coming soon</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-intro { max-width: 640px; color: var(--color-text-muted); margin-bottom: 2rem; }
  .photo-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 180px;
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
  }
  .photo-icon { font-size: 1.75rem; }
</style>
