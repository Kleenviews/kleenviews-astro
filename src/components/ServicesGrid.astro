---
import { services } from "../data/services";
---
<section id="services" class="section">
  <div class="container">
    <p class="eyebrow">What we do</p>
    <h2>Our Services</h2>
    <p class="section-intro">
      From weekly window rounds to one-off gutter clears — professional exterior cleaning
      across all services. Contact us for a free no-obligation quote.
    </p>

    <div class="grid grid-4">
      {services.map((service) => (
        <div class="card service-card">
          <span class="service-icon">{service.icon}</span>
          <h3>{service.title}</h3>
          <p>{service.description}</p>
          {service.fromPrice && <p class="price">From {service.fromPrice}</p>}
          <a href="#quote" class="btn btn-secondary btn-small">Request quote</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-intro { max-width: 640px; color: var(--color-text-muted); margin-bottom: 2rem; }
  .service-card { display: flex; flex-direction: column; gap: 0.5rem; }
  .service-icon { font-size: 1.75rem; }
  .service-card p { color: var(--color-text-muted); font-size: 0.95rem; margin: 0; }
  .price { font-weight: 600; color: var(--color-text) !important; }
  .btn-small { padding: 0.5rem 1.1rem; font-size: 0.9rem; margin-top: 0.5rem; align-self: flex-start; }
</style>
